<%- include('../partials/header', { titulo, paginaAtiva }) %>

<% if (mensagem) { %>
<div class="alert alert--<%= tipoMensagem %>" role="alert">
  <%= tipoMensagem === 'sucesso' ? '✅' : '❌' %> <%= mensagem %>
</div>
<% } %>

<!-- Barra de ações -->
<div class="page-actions">
  <div class="search-bar">
    <form method="GET" action="/produtos" id="form-busca" class="search-form">
      <div class="search-input-wrap">
        <svg class="search-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
        <input
          type="text"
          name="busca"
          id="busca"
          placeholder="Buscar produto..."
          value="<%= busca %>"
          class="search-input"
          autocomplete="off"
        />
      </div>
      <select name="categoria" id="filtro-categoria" class="select-input" onchange="this.form.submit()">
        <option value="">Todas as categorias</option>
        <% categorias.forEach(cat => { %>
          <option value="<%= cat %>" <%= categoriaFiltro === cat ? 'selected' : '' %>><%= cat %></option>
        <% }) %>
      </select>
      <button type="submit" class="btn btn--secondary btn--sm">Filtrar</button>
      <% if (busca || categoriaFiltro) { %>
        <a href="/produtos" class="btn btn--ghost btn--sm">Limpar</a>
      <% } %>
    </form>
  </div>

  <!-- Botão Novo Produto: apenas para admin -->
  <% if (user && user.role === 'admin') { %>
  <a href="/produtos/novo" class="btn btn--primary" id="btn-novo-produto">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" width="16" height="16"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
    Novo Produto
  </a>
  <% } %>
</div>

<!-- Tabela de Produtos -->
<div class="section-block">
  <% if (produtos.length === 0) { %>
    <div class="empty-state">
      <span class="empty-icon">📦</span>
      <p><% if (busca || categoriaFiltro) { %>Nenhum produto encontrado com os filtros selecionados.<% } else { %>Nenhum produto cadastrado ainda.<% } %></p>
      <% if (user && user.role === 'admin') { %>
      <a href="/produtos/novo" class="btn btn--primary">Cadastrar primeiro produto</a>
      <% } %>
    </div>
  <% } else { %>
  <div class="table-wrapper">
    <table class="data-table" id="tabela-produtos">
      <thead>
        <tr>
          <th>Nome</th>
          <th>Categoria</th>
          <th>Unidade</th>
          <th>Qtd. Atual</th>
          <th>Qtd. Mínima</th>
          <th>Preço Unit.</th>
          <th>Valor Total</th>
          <th>Status</th>
          <% if (user && user.role === 'admin') { %>
          <th class="text-center">Ações</th>
          <% } %>
        </tr>
      </thead>
      <tbody>
        <% produtos.forEach(p => { %>
        <tr class="<%= p.quantidade <= p.quantidadeMinima ? 'row--alert' : '' %>">
          <td><strong><%= p.nome %></strong></td>
          <td><span class="tag"><%= p.categoria %></span></td>
          <td class="text-muted"><%= p.unidade %></td>
          <td class="<%= p.quantidade <= p.quantidadeMinima ? 'text-danger' : 'text-success' %> font-semibold">
            <%= p.quantidade %>
          </td>
          <td class="text-muted"><%= p.quantidadeMinima %></td>
          <td>R$ <%= parseFloat(p.preco).toLocaleString('pt-BR', {minimumFractionDigits:2}) %></td>
          <td class="font-semibold">R$ <%= (p.quantidade * p.preco).toLocaleString('pt-BR', {minimumFractionDigits:2}) %></td>
          <td>
            <% if (p.quantidade <= p.quantidadeMinima) { %>
              <span class="badge badge--danger">⚠ Baixo</span>
            <% } else { %>
              <span class="badge badge--success">✓ Normal</span>
            <% } %>
          </td>
          <!-- Ações: apenas para admin -->
          <% if (user && user.role === 'admin') { %>
          <td>
            <div class="actions-cell">
              <a href="/produtos/<%= p.id %>/editar" class="btn btn--ghost btn--xs" title="Editar produto" id="btn-editar-<%= p.id %>">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="14" height="14"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                Editar
              </a>
              <form method="POST" action="/produtos/<%= p.id %>/excluir" class="form-delete" style="display:inline">
                <button type="submit" class="btn btn--danger btn--xs" title="Excluir produto" id="btn-excluir-<%= p.id %>">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="14" height="14"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/><path d="M10 11v6"/><path d="M14 11v6"/><path d="M9 6V4a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2"/></svg>
                  Excluir
                </button>
              </form>
            </div>
          </td>
          <% } %>
        </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
  <div class="table-footer">
    <span class="text-muted"><%= produtos.length %> produto(s) encontrado(s)</span>
  </div>
  <% } %>
</div>

<!-- Socket.io: atualiza lista em tempo real -->
<script>
  document.addEventListener('estoque:atualizado', function(e) {
    // Recarrega a página para refletir mudanças de estoque
    const tipos = ['produto_criado', 'produto_atualizado', 'produto_excluido', 'movimentacao_registrada'];
    if (tipos.includes(e.detail?.tipo)) {
      // Toast de notificação antes de recarregar
      const toast = document.createElement('div');
      toast.className = 'alert alert--sucesso';
      toast.style.cssText = 'position:fixed;top:1rem;right:1rem;z-index:9999;animation:fadeIn 0.3s ease';
      toast.textContent = '🔄 Estoque atualizado — recarregando...';
      document.body.appendChild(toast);
      setTimeout(() => location.reload(), 1200);
    }
  });
</script>

<%- include('../partials/footer') %>
