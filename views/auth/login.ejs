<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content="Login — ESTOQUE AGROPLANT" />
  <title>Login | ESTOQUE AGROPLANT</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --green-900: #14532d;
      --green-700: #15803d;
      --green-600: #16a34a;
      --green-500: #22c55e;
      --green-400: #4ade80;
      --dark-900: #0a0f0d;
      --dark-800: #0d1510;
      --dark-700: #111c15;
      --surface: rgba(255,255,255,0.04);
      --surface-hover: rgba(255,255,255,0.08);
      --border: rgba(255,255,255,0.08);
      --border-hover: rgba(255,255,255,0.15);
      --text-primary: #f0fdf4;
      --text-secondary: #86efac;
      --text-muted: #6b7280;
      --danger: #f87171;
      --danger-bg: rgba(248, 113, 113, 0.1);
      --blue-400: #60a5fa;
      --blue-500: #3b82f6;
      --blue-800: #1e40af;
      --blue-bg: rgba(59,130,246,0.08);
      --blue-border: rgba(96,165,250,0.25);
    }

    html, body {
      height: 100%;
      font-family: 'Inter', sans-serif;
      background: var(--dark-900);
      color: var(--text-primary);
      overflow: hidden;
    }

    /* ── Background ── */
    .login-bg {
      position: fixed;
      inset: 0;
      z-index: 0;
      background:
        radial-gradient(ellipse 80% 60% at 20% 10%, rgba(21,128,61,0.22) 0%, transparent 60%),
        radial-gradient(ellipse 60% 50% at 80% 90%, rgba(20,83,45,0.28) 0%, transparent 60%),
        linear-gradient(135deg, var(--dark-900) 0%, var(--dark-800) 50%, var(--dark-700) 100%);
    }

    /* Partículas flutuantes */
    .particles { position: fixed; inset: 0; z-index: 0; overflow: hidden; pointer-events: none; }
    .particle {
      position: absolute;
      border-radius: 50%;
      background: var(--green-500);
      opacity: 0;
      animation: float-particle linear infinite;
    }
    @keyframes float-particle {
      0%   { opacity: 0; transform: translateY(100vh) scale(0); }
      10%  { opacity: 0.25; }
      90%  { opacity: 0.08; }
      100% { opacity: 0; transform: translateY(-10vh) scale(1); }
    }

    /* ── Container ── */
    .login-wrapper {
      position: relative;
      z-index: 1;
      display: flex;
      align-items: center;
      justify-content: center;
      min-height: 100vh;
      padding: 1.5rem;
    }

    .login-card {
      width: 100%;
      max-width: 420px;
      background: rgba(13, 21, 16, 0.88);
      backdrop-filter: blur(28px);
      -webkit-backdrop-filter: blur(28px);
      border: 1px solid var(--border);
      border-radius: 24px;
      padding: 2.5rem;
      box-shadow:
        0 0 0 1px rgba(34,197,94,0.05),
        0 32px 64px rgba(0,0,0,0.65),
        0 0 80px rgba(21,128,61,0.07);
      animation: card-appear 0.5s cubic-bezier(0.34, 1.56, 0.64, 1) both;
    }

    @keyframes card-appear {
      from { opacity: 0; transform: translateY(32px) scale(0.96); }
      to   { opacity: 1; transform: translateY(0) scale(1); }
    }

    /* ── Logo / Brand ── */
    .brand-section {
      text-align: center;
      margin-bottom: 2rem;
    }

    /* Logo imagem circular (medal) */
    .brand-logo-img {
      display: block;
      width: 120px;
      height: 120px;
      border-radius: 50%;
      object-fit: cover;
      object-position: center;
      margin: 0 auto 1rem;
      border: 3px solid rgba(34,197,94,0.4);
      box-shadow:
        0 0 0 6px rgba(34,197,94,0.08),
        0 8px 32px rgba(0,0,0,0.5),
        0 0 40px rgba(34,197,94,0.15);
      animation: pulse-logo 3s ease-in-out infinite;
    }

    /* Fallback: emoji se a imagem não carregar */
    .brand-logo-fallback {
      display: none;
      width: 80px;
      height: 80px;
      background: linear-gradient(135deg, var(--green-700), var(--green-500));
      border-radius: 20px;
      font-size: 2.2rem;
      margin: 0 auto 1rem;
      align-items: center;
      justify-content: center;
      box-shadow: 0 8px 32px rgba(34,197,94,0.3);
      animation: pulse-logo 3s ease-in-out infinite;
    }

    @keyframes pulse-logo {
      0%, 100% { box-shadow: 0 0 0 6px rgba(34,197,94,0.08), 0 8px 32px rgba(0,0,0,0.5), 0 0 40px rgba(34,197,94,0.15); }
      50%       { box-shadow: 0 0 0 8px rgba(34,197,94,0.14), 0 8px 40px rgba(0,0,0,0.5), 0 0 56px rgba(34,197,94,0.22); }
    }

    .brand-name {
      display: block;
      font-size: 1.4rem;
      font-weight: 800;
      letter-spacing: 0.06em;
      background: linear-gradient(90deg, var(--green-400), var(--green-500));
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }

    .brand-sub {
      display: block;
      font-size: 0.75rem;
      font-weight: 400;
      color: var(--text-muted);
      letter-spacing: 0.15em;
      text-transform: uppercase;
      margin-top: 0.2rem;
    }

    .login-title {
      font-size: 0.95rem;
      font-weight: 500;
      color: var(--text-secondary);
      margin-top: 0.6rem;
    }

    /* ── Erro ── */
    .alert-error {
      display: flex;
      align-items: center;
      gap: 0.6rem;
      background: var(--danger-bg);
      border: 1px solid rgba(248,113,113,0.3);
      border-radius: 10px;
      padding: 0.75rem 1rem;
      font-size: 0.875rem;
      color: var(--danger);
      margin-bottom: 1.25rem;
      animation: shake 0.4s cubic-bezier(.36,.07,.19,.97) both;
    }

    @keyframes shake {
      10%, 90% { transform: translateX(-2px); }
      20%, 80% { transform: translateX(4px); }
      30%, 50%, 70% { transform: translateX(-4px); }
      40%, 60% { transform: translateX(4px); }
    }

    /* ── Form ── */
    .form-group { margin-bottom: 1.2rem; }

    .form-label {
      display: block;
      font-size: 0.78rem;
      font-weight: 600;
      color: var(--text-secondary);
      letter-spacing: 0.05em;
      text-transform: uppercase;
      margin-bottom: 0.45rem;
    }

    .input-wrapper { position: relative; }

    .input-icon {
      position: absolute;
      left: 1rem;
      top: 50%;
      transform: translateY(-50%);
      color: var(--text-muted);
      width: 17px;
      height: 17px;
      pointer-events: none;
      transition: color 0.2s;
    }

    .form-input {
      width: 100%;
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 12px;
      padding: 0.82rem 1rem 0.82rem 2.65rem;
      font-size: 0.93rem;
      font-family: 'Inter', sans-serif;
      color: var(--text-primary);
      outline: none;
      transition: border-color 0.2s, background 0.2s, box-shadow 0.2s;
    }

    .form-input::placeholder { color: var(--text-muted); }

    .form-input:focus {
      border-color: var(--green-500);
      background: var(--surface-hover);
      box-shadow: 0 0 0 3px rgba(34,197,94,0.12);
    }

    .input-wrapper:focus-within .input-icon { color: var(--green-400); }

    /* Toggle senha */
    .toggle-password {
      position: absolute;
      right: 1rem;
      top: 50%;
      transform: translateY(-50%);
      background: none;
      border: none;
      cursor: pointer;
      color: var(--text-muted);
      padding: 0;
      display: flex;
      align-items: center;
      transition: color 0.2s;
    }
    .toggle-password:hover { color: var(--green-400); }

    /* ── Botão principal (Entrar) ── */
    .btn-login {
      width: 100%;
      padding: 0.88rem;
      background: linear-gradient(135deg, var(--green-700), var(--green-600));
      border: none;
      border-radius: 12px;
      color: #fff;
      font-size: 0.93rem;
      font-weight: 700;
      font-family: 'Inter', sans-serif;
      cursor: pointer;
      letter-spacing: 0.04em;
      transition: opacity 0.2s, transform 0.15s, box-shadow 0.2s;
      box-shadow: 0 4px 20px rgba(34,197,94,0.28);
      margin-top: 0.5rem;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 0.5rem;
    }

    .btn-login:hover {
      opacity: 0.9;
      transform: translateY(-1px);
      box-shadow: 0 8px 28px rgba(34,197,94,0.38);
    }

    .btn-login:active { transform: translateY(0); }

    /* Loading */
    .btn-login.loading { opacity: 0.7; pointer-events: none; }
    .spinner {
      display: none;
      width: 16px;
      height: 16px;
      border: 2px solid rgba(255,255,255,0.3);
      border-top-color: #fff;
      border-radius: 50%;
      animation: spin 0.7s linear infinite;
    }
    .btn-login.loading .spinner { display: block; }
    .btn-login.loading .btn-text { display: none; }
    @keyframes spin { to { transform: rotate(360deg); } }

    /* ── Divisor ── */
    .divider {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      margin: 1.25rem 0;
    }
    .divider-line {
      flex: 1;
      height: 1px;
      background: var(--border);
    }
    .divider-text {
      font-size: 0.72rem;
      font-weight: 500;
      color: var(--text-muted);
      text-transform: uppercase;
      letter-spacing: 0.08em;
      white-space: nowrap;
    }

    /* ── Botão "Entrar como Visualizador" ── */
    .btn-viewer {
      width: 100%;
      padding: 0.78rem 1rem;
      background: var(--blue-bg);
      border: 1px solid var(--blue-border);
      border-radius: 12px;
      color: var(--blue-400);
      font-size: 0.88rem;
      font-weight: 600;
      font-family: 'Inter', sans-serif;
      cursor: pointer;
      letter-spacing: 0.02em;
      transition: background 0.2s, border-color 0.2s, transform 0.15s, color 0.2s;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 0.5rem;
    }

    .btn-viewer:hover {
      background: rgba(59,130,246,0.14);
      border-color: rgba(96,165,250,0.45);
      color: #93c5fd;
      transform: translateY(-1px);
    }

    .btn-viewer:active { transform: translateY(0); }

    .btn-viewer-icon {
      font-size: 1rem;
      line-height: 1;
    }

    /* Loading do viewer */
    .btn-viewer.loading {
      opacity: 0.6;
      pointer-events: none;
    }
  </style>
</head>
<body>

  <div class="login-bg"></div>
  <div class="particles" id="particles"></div>

  <div class="login-wrapper">
    <div class="login-card">

      <!-- ── Brand / Logo ── -->
      <div class="brand-section">
        <%
          // Tenta carregar a imagem oficial; se não existir, cai para emoji
        %>
        <img
          src="/img/logo-cana.jpg"
          alt="AgroPlant Cana 200"
          class="brand-logo-img"
          id="brandLogoImg"
          onerror="this.style.display='none'; document.getElementById('brandLogoFallback').style.display='inline-flex';"
        />
        <div class="brand-logo-fallback" id="brandLogoFallback">🌱</div>

        <span class="brand-name">AGROPLANT</span>
        <span class="brand-sub">Sistema de Estoque</span>
        <p class="login-title">Acesso restrito — identifique-se</p>
      </div>

      <!-- ── Alerta de erro ── -->
      <% if (erro) { %>
      <div class="alert-error" role="alert">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
          <circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/>
        </svg>
        <%= erro %>
      </div>
      <% } %>

      <!-- ── Formulário de login (para digitação manual) ── -->
      <form method="POST" action="/login" id="form-login" novalidate>

        <div class="form-group">
          <label for="username" class="form-label">Usuário</label>
          <div class="input-wrapper">
            <svg class="input-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
              <circle cx="12" cy="7" r="4"/>
            </svg>
            <input
              type="text"
              id="username"
              name="username"
              class="form-input"
              placeholder="seu_usuario"
              autocomplete="username"
              autocapitalize="off"
              spellcheck="false"
              required
            />
          </div>
        </div>

        <div class="form-group">
          <label for="password" class="form-label">Senha</label>
          <div class="input-wrapper">
            <svg class="input-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
              <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
            </svg>
            <input
              type="password"
              id="password"
              name="password"
              class="form-input"
              placeholder="••••••••"
              autocomplete="current-password"
              required
            />
            <button type="button" class="toggle-password" id="togglePwd" aria-label="Mostrar senha">
              <svg id="eye-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
                <circle cx="12" cy="12" r="3"/>
              </svg>
            </button>
          </div>
        </div>

        <button type="submit" class="btn-login" id="btn-login">
          <div class="spinner"></div>
          <span class="btn-text">Entrar no Sistema</span>
        </button>

      </form>

      <!-- ── Divisor ── -->
      <div class="divider">
        <div class="divider-line"></div>
        <span class="divider-text">ou acesso rápido</span>
        <div class="divider-line"></div>
      </div>

      <!-- ── Botão "Entrar como Visualizador" ── -->
      <%
        // Form oculto que submete as credenciais do viewer automaticamente
      %>
      <form method="POST" action="/login" id="form-viewer" style="display:none;">
        <input type="hidden" name="username" value="viewer" />
        <input type="hidden" name="password" value="viewer123" />
      </form>

      <button
        type="button"
        class="btn-viewer"
        id="btn-viewer"
        onclick="entrarComoViewer()"
        title="Acesso somente leitura — sem necessidade de senha"
      >
        <span class="btn-viewer-icon">👁</span>
        Entrar como Visualizador
      </button>

    </div>
  </div>

  <script>
    // ── Partículas flutuantes ──
    (function() {
      const container = document.getElementById('particles');
      for (let i = 0; i < 18; i++) {
        const p = document.createElement('div');
        p.className = 'particle';
        const size = Math.random() * 4 + 2;
        p.style.cssText = `
          width: ${size}px;
          height: ${size}px;
          left: ${Math.random() * 100}%;
          animation-duration: ${Math.random() * 12 + 8}s;
          animation-delay: ${Math.random() * 10}s;
          opacity: ${Math.random() * 0.2};
        `;
        container.appendChild(p);
      }
    })();

    // ── Toggle de visibilidade da senha ──
    const toggleBtn = document.getElementById('togglePwd');
    const pwdInput  = document.getElementById('password');

    toggleBtn?.addEventListener('click', () => {
      const isText = pwdInput.type === 'text';
      pwdInput.type = isText ? 'password' : 'text';
      toggleBtn.querySelector('svg').innerHTML = isText
        ? '<path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/>'
        : '<path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94"/><path d="M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19"/><line x1="1" y1="1" x2="23" y2="23"/>';
    });

    // ── Loading no submit do formulário principal ──
    document.getElementById('form-login')?.addEventListener('submit', () => {
      document.getElementById('btn-login').classList.add('loading');
    });

    // ── Entrar como Visualizador (auto-submit) ──
    function entrarComoViewer() {
      const btn = document.getElementById('btn-viewer');
      btn.classList.add('loading');
      btn.innerHTML = '<span style="font-size:0.85rem;opacity:0.8;">Entrando...</span>';
      document.getElementById('form-viewer').submit();
    }
  </script>

</body>
</html>
