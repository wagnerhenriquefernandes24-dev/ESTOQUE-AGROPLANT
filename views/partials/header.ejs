<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content="ESTOQUE AGROPLANT – Controle de Estoque para o Setor Agrícola" />
  <title><%= titulo %> | ESTOQUE AGROPLANT</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/css/style.css" />
</head>
<body>

  <!-- ══ SIDEBAR ══ -->
  <aside class="sidebar" id="sidebar" role="complementary" aria-label="Menu lateral">
    <div class="sidebar-header">
      <div class="brand">
        <span class="brand-icon">🌱</span>
        <div class="brand-text">
          <span class="brand-name">AGROPLANT</span>
          <span class="brand-sub">Estoque</span>
        </div>
      </div>
      <button class="sidebar-toggle" id="sidebarToggle" aria-label="Fechar menu">✕</button>
    </div>

    <nav class="sidebar-nav" role="navigation" aria-label="Menu principal">
      <a href="/" class="nav-item <%= paginaAtiva === 'dashboard' ? 'active' : '' %>" id="nav-dashboard">
        <span class="nav-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>
        </span>
        <span class="nav-label">Dashboard</span>
        <% if (paginaAtiva === 'dashboard') { %><span class="nav-active-bar"></span><% } %>
      </a>

      <a href="/produtos" class="nav-item <%= paginaAtiva === 'produtos' ? 'active' : '' %>" id="nav-produtos">
        <span class="nav-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/><polyline points="3.27 6.96 12 12.01 20.73 6.96"/><line x1="12" y1="22.08" x2="12" y2="12"/></svg>
        </span>
        <span class="nav-label">Produtos</span>
        <% if (paginaAtiva === 'produtos') { %><span class="nav-active-bar"></span><% } %>
      </a>

      <a href="/movimentacoes" class="nav-item <%= paginaAtiva === 'movimentacoes' ? 'active' : '' %>" id="nav-movimentacoes">
        <span class="nav-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><polyline points="17 1 21 5 17 9"/><path d="M3 11V9a4 4 0 0 1 4-4h14"/><polyline points="7 23 3 19 7 15"/><path d="M21 13v2a4 4 0 0 1-4 4H3"/></svg>
        </span>
        <span class="nav-label">Movimentações</span>
        <% if (paginaAtiva === 'movimentacoes') { %><span class="nav-active-bar"></span><% } %>
      </a>
    </nav>

    <!-- ── User info + Logout ── -->
    <div class="sidebar-footer">
      <div class="sidebar-divider"></div>
      <% if (user) { %>
      <div class="user-info">
        <div class="user-avatar"><%= user.nome ? user.nome.substring(0,2).toUpperCase() : 'AG' %></div>
        <div class="user-details">
          <span class="user-name"><%= user.nome %></span>
          <span class="user-role <%= user.role === 'admin' ? 'user-role--admin' : 'user-role--viewer' %>">
            <%= user.role === 'admin' ? '🔑 Administrador' : '👁 Visualizador' %>
          </span>
        </div>
      </div>
      <form method="POST" action="/logout" style="margin-top:0.75rem;">
        <button type="submit" class="btn-logout" id="btn-logout">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
          Sair
        </button>
      </form>
      <% } %>
    </div>
  </aside>

  <!-- Overlay mobile -->
  <div class="overlay" id="overlay" role="presentation"></div>

  <!-- ══ WRAPPER PRINCIPAL ══ -->
  <div class="main-wrapper">

    <header class="topbar" role="banner">
      <button class="menu-btn" id="menuBtn" aria-label="Abrir menu lateral" aria-expanded="false">
        <span></span><span></span><span></span>
      </button>
      <h1 class="page-title"><%= titulo %></h1>
      <div class="topbar-right">
        <% if (user && user.role === 'admin') { %>
        <span class="live-badge" id="liveBadge" title="Atualizações em tempo real ativas">
          <span class="live-dot"></span>
          Ao Vivo
        </span>
        <% } %>
        <span class="date-display" id="dateDisplay"></span>
        <% if (user && user.role === 'viewer') { %>
        <span class="viewer-badge">👁 Somente Leitura</span>
        <% } %>
      </div>
    </header>

    <main class="main-content" role="main">
